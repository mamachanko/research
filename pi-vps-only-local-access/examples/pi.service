[Unit]
Description=Pi coding agent service (VPS only)
After=network-online.target
Wants=network-online.target

[Service]
User=piagent
WorkingDirectory=/opt/pi
EnvironmentFile=/opt/pi/.env
ExecStart=/usr/local/bin/pi-server --host 127.0.0.1 --port 7777
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
